{
  "manifest_version": 3,
  "name": "EmailCraft AI",
  "version": "1.0.0",
  "description": "AI email composer that reads pages & respects your privacy. No email account access needed.",
  "permissions": ["activeTab", "scripting", "storage", "sidePanel"],
  "host_permissions": [
    "<all_urls>",
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.groq.com/*",
    "https://api.openai.com/*"
  ],
  "action": {
    "default_title": "Open EmailCraft AI",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
